# Copy to backend/.env (never commit .env)
SECRET_KEY=change-me-in-production
FLASK_DEBUG=1

# OpenAI (optional: without it, parsing/gap/roadmap use on-device heuristics)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# HTTPS sites: set SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SECURE=

# Override SQLite path (default: backend/instance/app.db)
# DATABASE_URL=sqlite:////absolute/path/app.db

# --- Mandatory email OTP (after password on login & register) ---
# Production: configure SMTP. For local dev without mail, set EMAIL_OTP_LOG_ONLY=1
# and read the OTP from the Flask console, or set EMAIL_OTP_BYPASS_CODE=123456 (dev only).
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
MAIL_USE_TLS=true
# MAIL_USE_SSL=true

EMAIL_OTP_TTL_MINUTES=10
EMAIL_OTP_MAX_ATTEMPTS=5
# EMAIL_OTP_LOG_ONLY=1
# EMAIL_OTP_BYPASS_CODE=
