# Copy to backend/.env (never commit .env)
SECRET_KEY=change-me-in-production
FLASK_DEBUG=1

# Listen port (wsgi.py). On macOS, AirPlay Receiver often uses 5000 — use 5001 and set the same
# FLASK_PORT in frontend/.env so the Vite proxy matches.
# PORT=5001

# Google Gemini (optional). GOOGLE_API_KEY is accepted as an alias.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Use true behind HTTPS only. For http://127.0.0.1:5173 leave empty or false so cookies work.
SESSION_COOKIE_SECURE=

# Optional: comma-separated browser origins if the Svelte app is served from another host.
# CORS_ORIGINS=https://example.com

# Override SQLite path (default: backend/instance/app.db)
# DATABASE_URL=sqlite:////absolute/path/app.db
