# Copy to backend/.env (never commit .env)
SECRET_KEY=change-me-in-production
FLASK_DEBUG=1

# Google Gemini (optional: from https://aistudio.google.com/apikey — without it, parsing/gap/roadmap use heuristics)
# GOOGLE_API_KEY is accepted as an alias for the same key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# HTTPS sites: set SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SECURE=

# Override SQLite path (default: backend/instance/app.db)
# DATABASE_URL=sqlite:////absolute/path/app.db
