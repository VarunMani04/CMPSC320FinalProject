# Copy to showcase/.env (gitignored). Never commit real secrets to tracked files.

# Required concept: URL of the Flask PostingPal API (same machine = default below).
# Must NOT be the Svelte/Vite URL (ports 5173 or 4173) — use Flask (default port 5000).
# If backend/.env has PORT=5001 (e.g. macOS AirPlay uses 5000), use the same port here.
API_BASE_URL=http://127.0.0.1:5000

# LLM keys live in backend/.env — Streamlit only calls Flask; Flask calls Gemini.
