# Never commit real .env — copy to .env locally.
#
# If Flask uses a non-default port (e.g. PORT=5001 in backend/.env because macOS uses 5000 for AirPlay):
# FLASK_PORT=5001
#
# Optional API base URL if Flask is not local (overrides FLASK_PORT for server-side /api proxy):
# API_ORIGIN=https://your-api.example.com
